  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "npm run lint:eslint && npm run lint:grounding-strict && npm run audit:inline-refs && npm run lint:translation-bridges",
    "lint:eslint": "eslint .",
    "lint:grounding": "node scripts/lint-grounding.mjs",
    "lint:grounding-strict": "node scripts/lint-grounding.mjs --strict",
    "audit:inline-refs": "node scripts/audit-inline-refs.mjs --strict",
    "lint:translation-bridges": "node scripts/lint-translation-bridges.mjs",
    "test": "vitest run",
    "preview": "vite preview",
    "audit:sources": "node scripts/audit-source-refs.mjs --fail-on=increase"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ogden/ui-components": "github:onaxyzogden/ogden-ui-components#v0.1.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.0",
    "react-router-dom": "^7.6.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@eslint/js": "^9.39.4",
    "@huggingface/transformers": "^4.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.5"
